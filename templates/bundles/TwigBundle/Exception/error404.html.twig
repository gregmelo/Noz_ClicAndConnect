{% extends 'base.html.twig' %}

{% block title %}Page non trouvée{% endblock %}

{% block body %}
<div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <div class="text-noz-blue mb-4">
        <svg class="w-24 h-24 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
    </div>
    <h1 class="text-4xl font-bold text-gray-800 mb-2">404</h1>
    <h2 class="text-2xl font-semibold text-gray-600 mb-6">Page non trouvée</h2>
    <p class="text-gray-500 mb-8 max-w-md">
        Oups ! La page que vous recherchez semble avoir été déplacée, supprimée ou n'a jamais existé.
    </p>
    <a href="{{ path('app_home') }}" class="bg-noz-btn text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition duration-300 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Retour à l'accueil
    </a>
</div>
{% endblock %}
