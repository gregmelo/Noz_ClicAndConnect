{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl font-bold mb-6 text-noz-blue">Mon Profil</h1>

        <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
            
            {# Bravo Message for Top Sellers #}
            {% if userRank is defined and userRank %}
                <div class="mb-6 p-4 rounded-lg bg-gradient-to-r from-yellow-100 to-yellow-200 border border-yellow-300 text-center" role="status" aria-label="Félicitations pour votre classement">
                    <div class="text-4xl mb-2" aria-hidden="true">
                        {% if userRank == 1 %}🥇{% elseif userRank == 2 %}🥈{% elseif userRank == 3 %}🥉{% endif %}
                    </div>
                    <h3 class="text-xl font-bold text-yellow-800">Félicitations !</h3>
                    <p class="text-yellow-900">
                        Bravo, vous êtes le 
                        <strong>
                            {% if userRank == 1 %}Premier{% elseif userRank == 2 %}Deuxième{% elseif userRank == 3 %}Troisième{% endif %}
                        </strong> 
                        meilleur vendeur !
                    </p>
                </div>
            {% endif %}

            <div class="mb-4">
                <p class="block text-gray-700 text-sm font-bold mb-1" aria-hidden="true">Email</p>
                <p class="text-gray-900"><span class="sr-only">Email : </span>{{ app.user.email }}</p>
            </div>

            <div class="mb-4">
                <p class="block text-gray-700 text-sm font-bold mb-1" aria-hidden="true">Prénom</p>
                <p class="text-gray-900"><span class="sr-only">Prénom : </span>{{ app.user.firstName }}</p>
            </div>

            <div class="mb-4">
                <p class="block text-gray-700 text-sm font-bold mb-1" aria-hidden="true">Nom</p>
                <p class="text-gray-900"><span class="sr-only">Nom : </span>{{ app.user.lastName }}</p>
            </div>

            <div class="mb-4">
                <p class="block text-gray-700 text-sm font-bold mb-1" aria-hidden="true">Rôle</p>
                <p class="text-gray-900">
                    <span class="sr-only">Rôle : </span>
                    {% if is_granted('ROLE_DEVELOPER') %}
                        Développeur
                    {% elseif is_granted('ROLE_SUPER_ADMIN') %}
                        Super Admin
                    {% elseif is_granted('ROLE_ADMIN') %}
                        Admin
                    {% elseif is_granted('ROLE_EMPLOYEE') %}
                        Employé
                    {% else %}
                        Client
                    {% endif %}
                </p>
            </div>

            {% if is_granted('ROLE_CLIENT') and not is_granted('ROLE_EMPLOYEE') %}
                <div class="mb-4">
                    <p class="block text-gray-700 text-sm font-bold mb-1" aria-hidden="true">Avertissements</p>
                    <div class="flex items-center gap-2">
                        <p class="text-gray-900"><span class="sr-only">Nombre d'avertissements : </span>{{ app.user.strikes }} / 3</p>
                        {% if app.user.strikes > 0 %}
                            <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-medium">
                                Attention
                            </span>
                        {% endif %}
                    </div>

                    {% if app.user.strikes > 0 %}
                        <div class="mt-3 p-3 bg-blue-50 border border-blue-100 rounded-lg">
                            <p class="text-xs text-blue-800 font-bold mb-2 uppercase tracking-wide">Progression Réhabilitation</p>
                            <div class="w-full bg-blue-200 rounded-full h-2 mb-1">
                                <div class="bg-blue-600 h-2 rounded-full transition-all duration-500" style="width: {{ (app.user.successfulCollectionsCount / 3 * 100)|round }}%"></div>
                            </div>
                            <p class="text-xs text-blue-700 mt-1">
                                {{ 3 - app.user.successfulCollectionsCount }} réservations réussies de plus pour effacer 1 strike.
                            </p>
                        </div>
                    {% endif %}

                    {% if app.user.banExpiresAt and app.user.banExpiresAt > date() %}
                        <p class="text-red-600 font-bold mt-2" role="alert">Banni jusqu'au {{ app.user.banExpiresAt|date('d/m/Y H:i') }}</p>
                    {% endif %}
                </div>
            {% endif %}

            <div class="flex flex-col sm:flex-row gap-3 mt-6">
                <a href="{{ path('app_profile_edit') }}" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-4 rounded text-center text-sm sm:text-base">
                    Modifier mes informations
                </a>
                <a href="{{ path('app_profile_change_password') }}" class="bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded text-center text-sm sm:text-base">
                    Changer mon mot de passe
                </a>
            </div>

            <div class="mt-8 pt-6 border-t border-gray-200">
                <h2 class="text-xl font-bold text-red-600 mb-4">Zone de Danger</h2>
                <p class="text-gray-600 mb-4">La suppression de votre compte est définitive et entraînera l'annulation de toutes vos réservations en cours.</p>
                
                <form action="{{ path('app_profile_delete') }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="w-full sm:w-auto bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded text-sm sm:text-base" data-confirm="Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible et annulera toutes vos réservations.">
                        Supprimer mon compte
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
