{# 
  Dashboard Home Template (Employee)
  Displays stats, low stock alerts, revenue, and urgent reservations.
  
  Variables:
  - totalProducts, productsInStock, productsOutOfStock: Stock stats
  - activeReservations, readyReservations, expiredReservations, collectedReservations: Reservation stats
  - totalRevenue: Total company revenue (float)
  - urgentReservations: List of ACTIVE reservations expiring soon
  - lowStockProducts: List of products with stock <= 3
  - bestSellers: Array of user/revenue data (Super Admin only)
#}
{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block body %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6 text-noz-blue">Tableau de Bord</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        {# CA Total #}
        <div class="bg-white rounded-lg shadow p-6 border-l-4 border-purple-500 relative overflow-hidden" data-controller="confetti" data-confetti-amount-value="{{ totalRevenue }}">
            <div class="flex items-center">
                <div class="p-3 rounded-full bg-purple-100 text-purple-500 mr-4">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                    <p class="text-sm text-gray-500 font-bold">Chiffre d'Affaires</p>
                    <p class="text-2xl font-bold text-gray-800" aria-label="Montant total : {{ totalRevenue|number_format(2, ',', ' ') }} euros">{{ totalRevenue|number_format(2, ',', ' ') }} €</p>
                </div>
            </div>
            {% set milestone = (totalRevenue / 1000)|round(0, 'floor') * 1000 %}
            {% if milestone >= 1000 %}
                 <div class="absolute top-0 right-0 m-2 text-xs font-bold text-purple-600 animate-bounce">
                    🎉 Cap des {{ milestone }}€ franchi !
                </div>
            {% endif %}
        </div>

        {# Total Produits #}
        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">Total Produits</p>
                    <p class="text-3xl font-bold text-noz-blue">{{ totalProducts }}</p>
                </div>
                <div class="bg-blue-100 rounded-full p-3">
                    <svg class="w-8 h-8 text-noz-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">En Stock</p>
                    <p class="text-3xl font-bold text-green-600">{{ productsInStock }}</p>
                </div>
                <div class="bg-green-100 rounded-full p-3">
                    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">Rupture</p>
                    <p class="text-3xl font-bold text-red-600">{{ productsOutOfStock }}</p>
                </div>
                <div class="bg-red-100 rounded-full p-3">
                    <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistiques Réservations -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">Réservation en attente</p>
                    <p class="text-3xl font-bold text-blue-600">{{ activeReservations }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">Prêtes à récupérer</p>
                    <p class="text-3xl font-bold text-purple-600">{{ readyReservations }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">Récupérées</p>
                    <p class="text-3xl font-bold text-green-600">{{ collectedReservations }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-500 text-sm uppercase">Expirées</p>
                    <p class="text-3xl font-bold text-orange-600">{{ expiredReservations }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Réservations Urgentes -->
    {% if urgentReservations|length > 0 %}
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Réservations Urgentes (< 6h)</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <p>{{ urgentReservations|length }} réservation(s) expire(nt) dans moins de 6 heures !</p>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Alertes Stock Bas -->
    {% if lowStockProducts|length > 0 %}
        <div class="bg-white rounded-lg shadow-md p-6 mb-8 border-l-4 border-orange-500">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-orange-800">
                <svg class="h-6 w-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Produits en Stock Bas ({{ lowStockProducts|length }})
            </h2>
            <!-- Desktop View (Table) -->
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full">
                    <thead>
                        <tr class="bg-orange-50">
                            <th scope="col" class="px-4 py-2 text-left text-orange-800">Produit</th>
                            <th scope="col" class="px-4 py-2 text-center text-orange-800">Catégorie</th>
                            <th scope="col" class="px-4 py-2 text-center text-orange-800">Stock Restant</th>
                            <th scope="col" class="px-4 py-2 text-right text-orange-800">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in lowStockProducts %}
                            <tr class="border-b border-orange-100 hover:bg-orange-50 transition">
                                <td class="px-4 py-3 font-medium text-gray-800">{{ product.name }}</td>
                                <td class="px-4 py-3 text-center text-gray-600">
                                    {{ product.category ? product.category.name : 'N/A' }}
                                </td>
                                <td class="px-4 py-3 text-center">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800 border border-orange-200">
                                        {{ product.stock }} article(s)
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="text-noz-blue hover:text-blue-800 font-bold text-sm">
                                        Modifier
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Mobile View (Cards) -->
            <div class="md:hidden space-y-4">
                {% for product in lowStockProducts %}
                    <div class="border border-orange-100 rounded-lg p-4 bg-orange-50/30">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="font-bold text-gray-800">{{ product.name }}</h3>
                            <span class="bg-orange-100 text-orange-800 text-[10px] font-bold px-2 py-0.5 rounded-full border border-orange-200">
                                {{ product.stock }} restants
                            </span>
                        </div>
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 italic">{{ product.category ? product.category.name : 'Sans catégorie' }}</span>
                            <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="text-noz-blue font-bold px-3 py-1 bg-white border border-noz-blue rounded shadow-sm">
                                Modifier
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    <!-- Réservations du jour -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-bold mb-4 text-noz-blue">Réservations à Récupérer Aujourd'hui ({{ reservationsToday|length }})</h2>
        {% if reservationsToday|length > 0 %}
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead>
                        <tr class="bg-gray-100">
                            <th scope="col" class="px-4 py-2 text-left">Client</th>
                            <th scope="col" class="px-4 py-2 text-left">Produit</th>
                            <th scope="col" class="px-4 py-2 text-center">Quantité</th>
                            <th scope="col" class="px-4 py-2 text-center">Expire à</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reservation in reservationsToday %}
                            <tr class="border-b">
                                <td class="px-4 py-2">{{ reservation.user.firstName }} {{ reservation.user.lastName }}</td>
                                <td class="px-4 py-2">
                                    <div class="font-bold text-xs text-noz-blue">{{ reservation.reference }}</div>
                                    <ul class="list-disc list-inside text-sm">
                                        {% for item in reservation.reservationItems %}
                                            <li>{{ item.quantity }}x {{ item.product.name }}</li>
                                        {% endfor %}
                                    </ul>
                                </td>
                                <td class="px-4 py-2 text-center">
                                    {% set totalQty = 0 %}
                                    {% for item in reservation.reservationItems %}
                                        {% set totalQty = totalQty + item.quantity %}
                                    {% endfor %}
                                    {{ totalQty }}
                                </td>
                                <td class="px-4 py-2 text-center">{{ reservation.expiresAt|date('H:i') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-gray-500">Aucune réservation à récupérer aujourd'hui.</p>
        {% endif %}
    </div>

    <!-- Best Sellers Leaderboard (Secret Section) -->
    {% if is_granted('ROLE_SUPER_ADMIN') or is_granted('ROLE_DEV') %}
        <div class="mt-8 bg-white rounded-lg shadow-md p-6">
            <h2 class="text-xl font-bold mb-4 flex items-center gap-2 text-noz-blue">
                🏆 Top Vendeurs (Classement Posteurs)
                <span class="text-xs bg-yellow-100 text-yellow-800 border border-yellow-200 px-2 py-1 rounded">Admin Only</span>
            </h2>
            
            {% if bestSellers|length > 0 %}
                <!-- Desktop View (Table) -->
                <div class="hidden md:block overflow-hidden rounded-lg border border-gray-200">
                    <table class="min-w-full text-sm">
                        <thead class="bg-gray-50 text-gray-700 uppercase font-medium">
                            <tr>
                                <th class="px-4 py-3 text-left">Rang</th>
                                <th class="px-4 py-3 text-left">Employé</th>
                                <th class="px-4 py-3 text-right">CA Généré</th>
                                <th class="px-4 py-3 text-center">Articles Vendus</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% for seller in bestSellers %}
                                <tr class="hover:bg-gray-50 transition text-gray-700">
                                    <td class="px-4 py-3 font-bold text-yellow-500 text-lg">
                                        {% if loop.index == 1 %}🥇{% elseif loop.index == 2 %}🥈{% elseif loop.index == 3 %}🥉{% else %}#{{ loop.index }}{% endif %}
                                    </td>
                                    <td class="px-4 py-3 font-bold">{{ seller.firstName }} {{ seller.lastName }}</td>
                                    <td class="px-4 py-3 text-right font-mono text-green-600 font-bold">{{ seller.revenue|number_format(2, ',', ' ') }} €</td>
                                    <td class="px-4 py-3 text-center font-medium">{{ seller.itemsSold }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <!-- Mobile View (Cards) -->
                <div class="md:hidden space-y-3">
                    {% for seller in bestSellers %}
                        <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 shadow-sm relative overflow-hidden">
                            {% if loop.index <= 3 %}
                                <div class="absolute -right-2 -top-2 w-12 h-12 flex items-center justify-center opacity-20">
                                    <span class="text-4xl">{% if loop.index == 1 %}🥇{% elseif loop.index == 2 %}🥈{% else %}🥉{% endif %}</span>
                                </div>
                            {% endif %}
                            
                            <div class="flex items-center gap-3 mb-2">
                                <div class="w-8 h-8 rounded-full bg-noz-blue text-white flex items-center justify-center font-bold text-xs ring-2 ring-blue-100">
                                    {{ loop.index }}
                                </div>
                                <h3 class="font-bold text-gray-900">{{ seller.firstName }} {{ seller.lastName }}</h3>
                            </div>
                            
                            <div class="flex justify-between items-end">
                                <div class="text-xs text-gray-500">
                                    <span class="font-bold text-noz-blue">{{ seller.itemsSold }}</span> articles vendus
                                </div>
                                <div class="text-lg font-black text-green-600 font-mono">
                                    {{ seller.revenue|number_format(2, ',', ' ') }} €
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-gray-400 italic">Pas encore assez de données pour établir le classement.</p>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
