{% extends 'base.html.twig' %}

{% block title %}Noz ClicAndConnect - Amberieu-en-Bugey{% endblock %}
{% block meta_description %}Découvrez les derniers arrivages NOZ à Amberieu-en-Bugey. Réservez vos articles en ligne via notre Clic & Collect et profitez des meilleures affaires.{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="bg-gradient-to-r from-noz-blue to-blue-600 rounded-xl shadow-lg mb-8 p-8 text-white relative overflow-hidden">
        <!-- Decorative Circle -->
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10 transform rotate-45"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="text-center md:text-left animate-fade-in-up">
                <h1 class="text-3xl md:text-5xl font-extrabold mb-2 tracking-tight">
                    ARRIVAGES DU JOUR
                    <span class="inline-block ml-2 bg-yellow-400 text-noz-blue text-xs px-2 py-1 rounded-full align-middle animate-pulse">NOUVEAU</span>
                </h1>
                <p class="text-lg md:text-xl text-white max-w-2xl">
                    Découvrez nos pépites du moment. Réservez en ligne, récupérez en magasin !
                </p>
            </div>
            
            <!-- Animated Icon -->
            <div class="hidden md:block animate-bounce-slow">
                <svg class="w-24 h-24 text-yellow-400 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path>
                </svg>
            </div>
        </div>
    </div>

    <div>
    <div class="mb-6">
        <form action="{{ path('app_home') }}" method="get" class="max-w-2xl mx-auto" data-controller="autosubmit">
            {% if min_price %}<input type="hidden" name="min_price" value="{{ min_price }}">{% endif %}
            {% if max_price %}<input type="hidden" name="max_price" value="{{ max_price }}">{% endif %}
            {% if availability %}<input type="hidden" name="availability" value="{{ availability }}">{% endif %}
            {% if sort %}<input type="hidden" name="sort" value="{{ sort }}">{% endif %}
            {% if currentCategory %}<input type="hidden" name="category" value="{{ currentCategory }}">{% endif %}
            
            <div class="flex flex-col sm:flex-row gap-2">
                <input type="text" name="search" value="{{ search }}" placeholder="Rechercher un produit..." 
                       data-action="input->autosubmit#debouncedSubmit"
                       class="flex-grow shadow appearance-none border rounded py-3 px-4 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-3 px-6 rounded">
                    Rechercher
                </button>
                <button type="button" 
                        onclick="toggleFilters()"
                        id="filter-toggle-btn"
                        class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-6 rounded flex items-center justify-center gap-2 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                    </svg>
                    <span id="filter-btn-text">{% if (min_price or max_price or availability or currentCategory) %}Masquer Filtres{% else %}Filtres{% endif %}</span>
                </button>
                {% if search %}
                    <a href="{{ path('app_home') }}" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-3 px-6 rounded">
                        Effacer
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Filters and Sorting -->
    <div id="filters-container" class="{% if not (min_price or max_price or availability or currentCategory) %}hidden{% endif %} mb-6 bg-white rounded-lg shadow-md p-4 animate-fade-in">
        <form action="{{ path('app_home') }}" method="get" class="space-y-4" data-controller="autosubmit">
            <!-- Keep search value -->
            {% if search %}
                <input type="hidden" name="search" value="{{ search }}">
            {% endif %}

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                <!-- Price Range -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Prix minimum</label>
                    <input type="number" name="min_price" value="{{ min_price }}" step="0.01" min="0" 
                           placeholder="0.00 €"
                           data-action="input->autosubmit#debouncedSubmit"
                           class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Prix maximum</label>
                    <input type="number" name="max_price" value="{{ max_price }}" step="0.01" min="0" 
                           placeholder="999.99 €"
                           data-action="input->autosubmit#debouncedSubmit"
                           class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                </div>

                <!-- Availability -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Disponibilité</label>
                    <select name="availability" 
                            data-action="change->autosubmit#submit"
                            class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                        <option value="">Tous</option>
                        <option value="in_stock" {% if availability == 'in_stock' %}selected{% endif %}>En stock</option>
                        <option value="out_of_stock" {% if availability == 'out_of_stock' %}selected{% endif %}>Rupture</option>
                        <option value="promotion" {% if availability == 'promotion' %}selected{% endif %}>En promotion</option>
                    </select>
                </div>

                <!-- Sorting -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Trier par</label>
                    <select name="sort" 
                            data-action="change->autosubmit#submit"
                            class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                        <option value="newest" {% if sort == 'newest' %}selected{% endif %}>Plus récents</option>
                        <option value="oldest" {% if sort == 'oldest' %}selected{% endif %}>Plus anciens</option>
                        <option value="price_asc" {% if sort == 'price_asc' %}selected{% endif %}>Prix croissant</option>
                        <option value="price_desc" {% if sort == 'price_desc' %}selected{% endif %}>Prix décroissant</option>
                        <option value="name_asc" {% if sort == 'name_asc' %}selected{% endif %}>Nom A-Z</option>
                    </select>
                </div>

                <!-- Category -->
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Catégorie</label>
                    <select name="category" 
                            data-action="change->autosubmit#submit"
                            class="w-full shadow appearance-none border rounded py-2 px-3 text-noz-blue font-bold leading-tight focus:outline-none focus:shadow-outline bg-blue-50">
                        <option value="">Toutes catégories</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {% if currentCategory == category.id %}selected{% endif %}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="flex gap-2 justify-end">
                <noscript>
                    <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-6 rounded">
                        Appliquer les filtres
                    </button>
                </noscript>
                <a href="{{ path('app_home') }}" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-6 rounded">
                    Réinitialiser
                </a>
            </div>
        </form>
    </div>
    </div>
    
    <!-- Results count -->
    <div class="mb-4 text-gray-600">
        <strong>{{ products|length }}</strong> produit(s) sur cette page
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {% for product in products %}
            <div class="border rounded-lg p-4 shadow-md bg-white flex flex-col h-full hover:shadow-lg transition-shadow relative group">
                {# Top Part (Linkable) #}
                <a href="{{ path('app_product_show_public', {id: product.id}) }}" class="block flex-grow cursor-pointer group">
                    <div class="relative h-64 bg-gray-100 flex items-center justify-center overflow-hidden mb-4 rounded group-hover:bg-gray-200 transition-colors">
                        {% if product.imageFilename %}
                            <img src="{{ asset('uploads/images/' ~ product.imageFilename) }}" 
                                 alt="{{ product.name }}" 
                                 class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-300">
                        {% else %}
                            <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                        {% endif %}
                        
                    </div>
                    
                    <h2 class="text-xl font-bold mb-1 text-noz-blue group-hover:underline">{{ product.name }}</h2>
                    {% if product.category %}
                        <div class="mb-2">
                            <span class="text-[10px] uppercase tracking-wider font-bold bg-blue-100 text-noz-blue px-2 py-0.5 rounded-full">
                                {{ product.category.name }}
                            </span>
                        </div>
                    {% endif %}
                    <p class="text-gray-600 mb-4 line-clamp-2">{{ product.description }}</p>
                </a>
                
                {# Bottom Part (Interactive) #}
                <div class="mt-auto pt-4 border-t border-gray-50">
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 gap-2">
                        <div class="flex flex-col">
                            {% if product.originalPrice and product.originalPrice > product.price %}
                                <span class="text-xs text-gray-500 line-through">{{ product.originalPrice }} €</span>
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="text-2xl font-bold text-noz-red">{{ product.price }} €</span>
                                    <div class="flex items-center gap-1">
                                        <span class="bg-red-100 text-red-800 text-[10px] font-bold px-1.5 py-0.5 rounded animate-blink whitespace-nowrap">Baisse de prix</span>
                                        <span class="bg-red-500 text-white text-[10px] font-black px-1.5 py-0.5 rounded">
                                            -{{ ((product.originalPrice - product.price) / product.originalPrice * 100)|round }}%
                                        </span>
                                    </div>
                                </div>
                            {% else %}
                                <span class="text-2xl font-bold text-noz-red">{{ product.price }} €</span>
                            {% endif %}
                        </div>
                        
                        <div class="flex items-center">
                            {% if product.stock > 0 %}
                                <span class="text-sm font-bold bg-green-50 text-green-800 px-2 py-1 rounded-full border border-green-100">
                                    Stock: {{ product.stock }}
                                </span>
                            {% else %}
                                <span class="text-sm font-bold bg-red-50 text-red-800 px-2 py-1 rounded-full border border-red-100">
                                    Rupture
                                </span>
                            {% endif %}
                        </div>
                    </div>

                    {% if app.user %}
                        {% if product.stock > 0 %}
                            <form action="{{ path('app_cart_add', {'id': product.id}) }}" method="post" class="flex gap-2">
                                <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart') }}">
                                <input type="number" name="quantity" value="1" min="1" max="{{ product.stock }}" class="border rounded px-2 py-1 w-20 text-center">
                                <button type="submit" class="flex-grow bg-noz-btn text-white py-2 rounded hover:bg-blue-700 font-bold uppercase text-sm flex items-center justify-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                    </svg>
                                    Ajouter
                                </button>
                            </form>
                        {% else %}
                            <button disabled class="w-full bg-gray-300 text-gray-500 py-2 rounded font-bold uppercase text-sm cursor-not-allowed">
                                Rupture de stock
                            </button>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_login') }}" class="block w-full text-center bg-gray-800 text-white py-2 rounded hover:bg-gray-700 font-bold uppercase text-sm">
                            Connectez-vous pour réserver
                        </a>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div class="col-span-full text-center py-12 text-gray-500">
                <p class="text-xl">Aucun produit trouvé.</p>
            </div>
        {% endfor %}
    </div>

    <!-- Pagination -->
    {% if totalPages > 1 %}
        <div class="mt-8 flex justify-center">
            <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                <!-- Previous -->
                {% if currentPage > 1 %}
                    <a href="{{ path('app_home', {page: currentPage - 1, search: search, min_price: min_price, max_price: max_price, availability: availability, sort: sort, category: currentCategory}) }}" 
                       class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                        ‹ Précédent
                    </a>
                {% else %}
                    <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-gray-50 text-sm font-medium text-gray-500 cursor-not-allowed" aria-disabled="true">
                        ‹ Précédent
                    </span>
                {% endif %}

                <!-- Page numbers -->
                {% for page in 1..totalPages %}
                    {% if page == currentPage %}
                        <span class="relative inline-flex items-center px-4 py-2 border border-noz-blue bg-noz-blue text-sm font-medium text-white">
                            {{ page }}
                        </span>
                    {% elseif page == 1 or page == totalPages or (page >= currentPage - 2 and page <= currentPage + 2) %}
                        <a href="{{ path('app_home', {page: page, search: search, min_price: min_price, max_price: max_price, availability: availability, sort: sort, category: currentCategory}) }}" 
                           class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                            {{ page }}
                        </a>
                    {% elseif page == currentPage - 3 or page == currentPage + 3 %}
                        <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
                            ...
                        </span>
                    {% endif %}
                {% endfor %}

                <!-- Next -->
                {% if currentPage < totalPages %}
                    <a href="{{ path('app_home', {page: currentPage + 1, search: search, min_price: min_price, max_price: max_price, availability: availability, sort: sort, category: currentCategory}) }}" 
                       class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                        Suivant ›
                    </a>
                {% else %}
                    <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-gray-50 text-sm font-medium text-gray-500 cursor-not-allowed" aria-disabled="true">
                        Suivant ›
                    </span>
                {% endif %}
            </nav>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    function toggleFilters() {
        const container = document.getElementById('filters-container');
        const textBtn = document.getElementById('filter-btn-text');
        
        if (container.classList.contains('hidden')) {
            container.classList.remove('hidden');
            textBtn.textContent = 'Masquer Filtres';
        } else {
            container.classList.add('hidden');
            textBtn.textContent = 'Filtres';
        }
    }
</script>
{% endblock %}
