{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}
{% block meta_robots %}noindex, nofollow{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-noz-blue">Mon Panier</h1>

    {% if cart|length > 0 %}
        <!-- Desktop View (Table) -->
        <div class="hidden md:block bg-white rounded-lg shadow-md overflow-hidden mb-8">
            <table class="min-w-full divide-y divide-gray-200" aria-label="Récapitulatif de votre panier">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Produit</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Prix</th>
                        <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Quantité</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for item in cart %}
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    {% if item.product.imageFilename %}
                                        <img class="h-10 w-10 rounded-full object-cover mr-4" src="{{ asset('uploads/images/' ~ item.product.imageFilename) }}" alt="{{ item.product.name }}">
                                    {% else %}
                                        <div class="h-10 w-10 rounded-full bg-gray-200 mr-4 flex items-center justify-center text-gray-500">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                    {% endif %}
                                    <div class="text-sm font-medium text-gray-900">{{ item.product.name }}</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {{ item.product.price }} €
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                <div class="flex justify-center items-center space-x-2">
                                    <a href="{{ path('app_cart_decrease', {'id': item.product.id}) }}" 
                                       aria-label="Diminuer la quantité de {{ item.product.name }}" 
                                       class="text-gray-500 hover:text-red-600 font-bold px-2 border rounded">-</a>
                                    <span aria-label="Quantité actuelle : {{ item.quantity }}">{{ item.quantity }}</span>
                                    <form action="{{ path('app_cart_add', {'id': item.product.id}) }}" method="post" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart') }}">
                                        <input type="hidden" name="returnToCart" value="1">
                                        <button type="submit" aria-label="Augmenter la quantité de {{ item.product.name }}" class="text-gray-500 hover:text-green-600 font-bold px-2 border rounded">+</button>
                                    </form>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold text-gray-900">
                                {{ item.product.price * item.quantity }} €
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="{{ path('app_cart_remove', {'id': item.product.id}) }}" class="text-red-600 hover:text-red-900">Supprimer</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot class="bg-gray-50">
                    <tr>
                        <td colspan="3" class="px-6 py-4 text-right font-bold text-gray-900">Total</td>
                        <td class="px-6 py-4 text-right font-bold text-xl text-noz-red whitespace-nowrap">{{ total }} €</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <!-- Mobile View (Cards) -->
        <div class="md:hidden space-y-4 mb-8">
            {% for item in cart %}
                <div class="bg-white rounded-lg shadow p-4 flex gap-4">
                    <!-- Image -->
                    <div class="flex-shrink-0">
                        {% if item.product.imageFilename %}
                            <img class="h-20 w-20 rounded object-cover" src="{{ asset('uploads/images/' ~ item.product.imageFilename) }}" alt="{{ item.product.name }}">
                        {% else %}
                            <div class="h-20 w-20 rounded bg-gray-200 flex items-center justify-center text-gray-500">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- Content -->
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-start">
                            <h3 class="font-bold text-gray-900 truncate pr-2">{{ item.product.name }}</h3>
                            <a href="{{ path('app_cart_remove', {'id': item.product.id}) }}" class="text-red-500 hover:text-red-700" aria-label="Supprimer {{ item.product.name }} du panier">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </a>
                        </div>
                        
                        <p class="text-sm text-gray-500 mb-2">{{ item.product.price }} €</p>
                        
                        <div class="flex justify-between items-end mt-2">
                            <!-- Qty Controls -->
                            <div class="flex items-center space-x-3 border rounded px-2 py-1 bg-gray-50">
                                <a href="{{ path('app_cart_decrease', {'id': item.product.id}) }}" aria-label="Diminuer la quantité de {{ item.product.name }}" class="text-gray-500 hover:text-red-600 font-bold px-2">-</a>
                                <span class="font-medium" aria-label="Quantité: {{ item.quantity }}">{{ item.quantity }}</span>
                                <form action="{{ path('app_cart_add', {'id': item.product.id}) }}" method="post" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart') }}">
                                    <input type="hidden" name="returnToCart" value="1">
                                    <button type="submit" aria-label="Augmenter la quantité de {{ item.product.name }}" class="text-gray-500 hover:text-green-600 font-bold px-2">+</button>
                                </form>
                            </div>
                            
                            <span class="font-bold text-lg text-noz-red">{{ item.product.price * item.quantity }} €</span>
                        </div>
                    </div>
                </div>
            {% endfor %}

            <!-- Mobile Total -->
            <div class="bg-white rounded-lg shadow p-4 flex justify-between items-center">
                <span class="font-bold text-gray-900">Total Panier</span>
                <span class="font-bold text-xl text-noz-red whitespace-nowrap">{{ total }} €</span>
            </div>
        </div>

    <style>
        @media (max-width: 780px) {
            .cart-actions-container {
                flex-direction: column-reverse;
                align-items: center;
                gap: 1rem;
            }
            .cart-actions-btn {
                width: 100% !important;
                margin: 0 !important;
            }
        }
    </style>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-bold mb-4 text-noz-blue">Finaliser ma réservation</h2>
        
        <form action="{{ path('app_reservation_validate') }}" method="post" aria-label="Validation de votre réservation">
            <input type="hidden" name="_token" value="{{ csrf_token('reservation_validate') }}">
            
            <div class="mb-6">
                <label for="comment" class="block text-gray-700 text-sm font-bold mb-2">Commentaire (optionnel)</label>
                <textarea name="comment" id="comment" rows="3" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:ring-2 focus:ring-noz-blue" placeholder="Précisions sur votre commande (ex: pointure, couleur préférée...)"></textarea>
            </div>

            <div class="cart-actions-container flex flex-wrap justify-end gap-3 lg:gap-4">
                <a href="{{ path('app_cart_clear') }}" class="cart-actions-btn bg-red-500 hover:bg-red-700 text-white font-bold py-3 sm:py-2 px-6 rounded text-center order-3 sm:order-1" data-confirm="Êtes-vous sûr de vouloir vider votre panier ? Tous les articles seront supprimés.">
                    Vider le panier
                </a>
                <a href="{{ path('app_home') }}" class="cart-actions-btn bg-gray-500 hover:bg-gray-700 text-white font-bold py-3 sm:py-2 px-6 rounded text-center order-2">
                    Continuer mes achats
                </a>
                <button type="submit" class="cart-actions-btn bg-noz-btn hover:bg-blue-700 text-white font-bold py-3 sm:py-2 px-6 rounded order-1 sm:order-3">
                    Valider la réservation
                </button>
            </div>
        </form>
    </div>
{% else %}
        <div class="text-center py-12 bg-white rounded-lg shadow-md">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Votre panier est vide</h3>
            <p class="mt-1 text-sm text-gray-500">Commencez par ajouter des produits.</p>
            <div class="mt-6">
                <a href="{{ path('app_home') }}" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-noz-btn hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Voir les produits
                </a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
