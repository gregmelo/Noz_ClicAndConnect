{% extends 'base.html.twig' %}

{% block title %}Logs d'Audit d'Activité{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <h1 class="text-3xl font-bold text-noz-blue">Traçabilité & Audit</h1>
        <div class="flex flex-wrap items-center gap-3">
            <a href="{{ path('app_admin_audit_purge') }}" class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded-full shadow text-xs transition-all flex items-center gap-2" onclick="return confirm('Attention : Cette action va supprimer DÉFINITIVEMENT tous les logs d’audit. Confirmer ?');">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                Purger
            </a>
            <a href="{{ path('app_admin_audit_sync_db') }}" class="bg-noz-yellow hover:bg-yellow-400 text-noz-black font-bold py-2 px-4 rounded-full shadow text-xs transition-all flex items-center gap-2" onclick="return confirm('Cette action va synchroniser la base de données. Continuer ?');">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Sync DB
            </a>
            <div class="text-xs text-gray-500 bg-gray-100 px-4 py-2 rounded-full">
                {{ logs|length }} derniers évènements
            </div>
        </div>
    </div>

    {# Desktop/Tablet Table #}
    <div class="hidden md:block bg-white shadow-xl rounded-lg overflow-hidden border border-gray-100">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Date & Heure</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Utilisateur</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Action</th>
                        <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Détails</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for log in logs %}
                        {% include 'admin/audit/_log_row.html.twig' with {'log': log, 'is_mobile': false} %}
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-6 py-10 text-center text-gray-400 italic">
                                Aucun log d'activité trouvé.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# Mobile List #}
    <div class="md:hidden space-y-4">
        {% for log in logs %}
            {% include 'admin/audit/_log_row.html.twig' with {'log': log, 'is_mobile': true} %}
        {% else %}
            <div class="bg-white p-8 text-center text-gray-400 italic rounded-lg border">
                Aucun log d'activité trouvé.
            </div>
        {% endfor %}
    </div>
    
    <div class="mt-8 p-4 bg-blue-50 border border-blue-100 rounded-lg flex items-center gap-4 text-blue-700 text-sm">
        <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p>Les logs sont automatiquement supprimés après 2 mois pour garantir les performances du serveur.</p>
    </div>
</div>
{% endblock %}
