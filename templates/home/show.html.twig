{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<meta name="turbo-visit-control" content="reload">
<div class="container mx-auto px-4 py-8">
    <div class="mb-6">
        <a href="{{ path('app_home') }}" class="text-noz-blue hover:underline flex items-center gap-2 font-bold">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Retour à la liste des produits
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-0">
            {# Image Section (carrousel) #}
            <div class="lg:col-span-3 bg-gray-50 p-4 flex flex-col gap-4">
                {% set images = [] %}
                {% if product.imageFilename %}
                    {% set images = images|merge([product.imageFilename]) %}
                {% endif %}
                {% for filename in product.extraImages ?? [] %}
                    {% set images = images|merge([filename]) %}
                {% endfor %}

                <div id="product-carousel" class="relative flex items-center justify-center">
                    {% if images is not empty %}
                        {% for filename in images %}
                            <img src="{{ asset('uploads/images/' ~ filename) }}"
                                 alt="{{ product.name }} - photo {{ loop.index }}"
                                 class="product-slide max-w-full max-h-[500px] object-contain rounded-lg shadow-sm cursor-pointer hover:opacity-90 transition {% if not loop.first %}hidden{% endif %}"
                                 data-index="{{ loop.index0 }}"
                                 data-lightbox-src="{{ asset('uploads/images/' ~ filename) }}"
                                 title="Cliquez pour agrandir">
                        {% endfor %}
                    {% else %}
                        <div class="w-full h-96 bg-gray-200 flex items-center justify-center text-gray-400">
                            <svg class="w-20 h-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                    {% endif %}
                </div>

                {% if images|length > 1 %}
                    <div class="mt-3 flex flex-wrap gap-2 justify-center">
                        {% for filename in images %}
                            <button type="button" class="product-thumb border-2 border-transparent rounded-md overflow-hidden focus:outline-none focus:ring-2 focus:ring-noz-blue {% if loop.first %}border-noz-blue{% endif %}" data-index="{{ loop.index0 }}">
                                <img src="{{ asset('uploads/images/' ~ filename) }}"
                                     alt="{{ product.name }} - vignette {{ loop.index }}"
                                     class="w-16 h-16 object-cover">
                            </button>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Details Section #}
            <div class="lg:col-span-2 p-8 lg:p-12 flex flex-col">
                <div class="flex-grow">
                    {% if product.category %}
                        <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-noz-blue/10 text-noz-blue mb-4 uppercase tracking-wider">
                            {{ product.category.name }}
                        </span>
                    {% endif %}

                    <h1 class="text-4xl font-extrabold text-gray-900 mb-6 leading-tight">{{ product.name }}</h1>

                    <div class="flex items-baseline gap-4 mb-8">
                        <span class="text-3xl md:text-4xl font-black text-noz-blue">{{ product.price|number_format(2, ',', ' ') }} €</span>
                        {% if product.originalPrice and product.originalPrice > product.price %}
                            <span class="text-lg md:text-xl text-gray-400 line-through font-bold">{{ product.originalPrice|number_format(2, ',', ' ') }} €</span>
                            <span class="bg-red-500 text-white px-2 py-1 rounded-lg text-sm font-bold animate-pulse">
                                -{{ ((product.originalPrice - product.price) / product.originalPrice * 100)|round }}%
                            </span>
                        {% endif %}
                    </div>

                    <div class="prose prose-blue max-w-none text-gray-600 mb-8 leading-relaxed">
                        <h3 class="text-lg font-bold text-gray-800 mb-2 uppercase tracking-tight border-b-2 border-gray-100 pb-1">Description</h3>
                        {{ product.description|nl2br }}
                    </div>

                    {% if product.isAlcohol %}
                    <div class="flex items-start gap-3 bg-amber-50 border border-amber-300 rounded-lg px-4 py-3 mb-6" role="alert">
                        <span class="text-amber-600 text-xl leading-none mt-0.5" aria-hidden="true">⚠️</span>
                        <p class="text-xs text-amber-800 leading-relaxed">
                            <strong>L'abus d'alcool est dangereux pour la santé, à consommer avec modération.</strong>
                            La vente d'alcool est interdite aux mineurs de moins de 18 ans
                            (Art. L.3342-1 du Code de la Santé Publique).
                        </p>
                    </div>
                    {% endif %}

                    <div class="flex items-center gap-3 mb-8">
                        <div class="flex items-center gap-2">
                            {% if product.stock > 0 %}
                                <div class="w-3 h-3 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></div>
                                <span class="text-green-700 font-bold uppercase text-xs tracking-wider">En stock</span>
                            {% else %}
                                <div class="w-3 h-3 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.6)]"></div>
                                <span class="text-red-700 font-bold uppercase text-xs tracking-wider">Épuisé</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Footer / Action #}
                <div class="pt-8 border-t border-gray-100 mt-auto">
                    {% if product.stock > 0 %}
                        {% if app.user %}
                            <form action="{{ path('app_cart_add', {'id': product.id}) }}" method="POST" class="flex gap-2">
                                <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart') }}">
                                <input type="hidden" name="returnToCart" value="1">
                                <label for="quantity" class="sr-only">Quantité</label>
                                <input type="number" id="quantity" name="quantity" value="1" min="1" max="{{ product.stock }}"
                                       class="border rounded px-2 py-1 w-20 text-center text-noz-blue font-bold">
                                <button type="submit" aria-label="Ajouter {{ product.name }} au panier" class="flex-grow bg-noz-btn text-white py-2 rounded hover:bg-blue-700 font-bold uppercase text-sm flex items-center justify-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                    Ajouter au panier
                                </button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="block w-full text-center bg-gray-800 text-white py-4 rounded-xl hover:bg-gray-700 font-bold uppercase text-sm">
                                Connectez-vous pour ajouter au panier
                            </a>
                        {% endif %}
                    {% else %}
                        <button disabled class="w-full bg-gray-200 text-gray-400 font-black py-4 rounded-xl flex items-center justify-center gap-3 uppercase tracking-widest cursor-not-allowed">
                            Indisponible
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
<script>
(function() {
    const container = document.getElementById('product-carousel');
    if (!container) return;
    const slides = Array.from(container.querySelectorAll('.product-slide'));
    const thumbs = Array.from(document.querySelectorAll('.product-thumb'));
    if (!slides.length) return;
    let current = 0;
    function showSlide(index) {
        if (index < 0 || index >= slides.length) return;
        slides.forEach((img, i) => { img.classList.toggle('hidden', i !== index); });
        thumbs.forEach((btn, i) => {
            btn.classList.toggle('border-noz-blue', i === index);
        });
        current = index;
    }
    thumbs.forEach(btn => {
        btn.addEventListener('click', function() {
            showSlide(parseInt(btn.dataset.index || '0', 10));
        });
    });
    showSlide(current);
})();
</script>
{% endblock %}