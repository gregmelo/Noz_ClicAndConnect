{% extends 'base.html.twig' %}

{% block title %}Réservations à Récupérer{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-2xl sm:text-3xl font-bold mb-6 text-noz-blue">Réservations à Récupérer</h1>

    <!-- Desktop: Table view (hidden on mobile) -->
    <div class="hidden lg:block bg-white shadow-md rounded my-6">
        <div class="overflow-x-auto">
            <table class="min-w-full table-auto">
            <thead>
                <tr class="bg-gray-200 text-gray-600 uppercase text-sm leading-normal">
                    <th class="py-3 px-6 text-left">Client</th>
                    <th class="py-3 px-6 text-left">Référence / Articles</th>
                    <th class="py-3 px-6 text-center">Réservé le</th>
                    <th class="py-3 px-6 text-center">Expire le</th>
                    <th class="py-3 px-6 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="text-gray-600 text-sm font-light">
                {% for reservation in reservations %}
                    <tr class="border-b border-gray-200 hover:bg-gray-100">
                        <td class="py-3 px-6 text-left">
                            <div>
                                <div class="font-medium">{{ reservation.user.firstName }} {{ reservation.user.lastName }}</div>
                                <div class="text-xs text-gray-500">{{ reservation.user.email }}</div>
                            </div>
                        </td>
                        <td class="py-3 px-6 text-left">
                            <div class="font-bold text-noz-blue">{{ reservation.reference }}</div>
                            <ul class="list-disc list-inside mt-1">
                                {% for item in reservation.reservationItems %}
                                    <li>{{ item.quantity }}x <span class="font-medium">{{ item.product.name }}</span></li>
                                {% endfor %}
                            </ul>
                            {% if reservation.comment %}
                                <div class="text-xs text-gray-500 mt-1 italic bg-yellow-50 p-1 rounded border border-yellow-100">
                                    <span class="font-bold">Note:</span> {{ reservation.comment }}
                                </div>
                            {% endif %}
                        </td>
                        <td class="py-3 px-6 text-center">
                            {{ reservation.reservedAt|date('d/m/Y H:i') }}
                        </td>
                        <td class="py-3 px-6 text-center">
                            {% set now = date() %}
                            {% set timeLeft = date(reservation.expiresAt).diff(now) %}
                            {% if reservation.expiresAt < now %}
                                <span class="text-red-600 font-bold">Expirée</span>
                            {% else %}
                                <span class="{% if timeLeft.h < 6 %}text-orange-600{% else %}text-green-600{% endif %}">
                                    {{ reservation.expiresAt|date('d/m/Y H:i') }}
                                </span>
                            {% endif %}
                            
                            {% if reservation.status == 'READY' %}
                                <div class="mt-1">
                                    <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded">PRÊTE</span>
                                </div>
                            {% endif %}
                        </td>
                        <td class="py-3 px-6 text-center space-y-2">
                            {% if reservation.status == 'ACTIVE' %}
                                <form action="{{ path('app_reservation_ready', {'id': reservation.id}) }}" method="post" class="inline-block">
                                    <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-1 px-3 rounded text-xs w-full mb-1">
                                        🚀 Prête
                                    </button>
                                </form>
                            {% endif %}
                            
                            <form action="{{ path('app_reservation_collect', {'id': reservation.id}) }}" method="post" class="inline-block">
                                <button type="submit" class="bg-green-500 hover:bg-green-700 text-white font-bold py-1 px-3 rounded text-xs w-full">
                                    ✓ Récupéré
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="py-3 px-6 text-center">Aucune réservation active.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>

    <!-- Mobile/Tablet: Card view (hidden on desktop) -->
    <div class="lg:hidden space-y-3 sm:space-y-4">
        {% for reservation in reservations %}
            {% set now = date() %}
            {% set timeLeft = date(reservation.expiresAt).diff(now) %}
            {% set isExpired = reservation.expiresAt < now %}
            {% set isUrgent = timeLeft.h < 6 and not isExpired %}
            
            <div class="bg-white rounded-lg shadow-md p-3 sm:p-4 {% if isExpired %}border-l-4 border-red-500{% elseif isUrgent %}border-l-4 border-orange-500{% else %}border-l-4 border-green-500{% endif %}">
                <!-- Client Info -->
                <div class="mb-3 pb-3 border-b border-gray-200">
                    <div class="flex items-center gap-2 mb-1">
                        <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        <span class="font-bold text-base sm:text-lg text-gray-800">{{ reservation.user.firstName }} {{ reservation.user.lastName }}</span>
                    </div>
                    <div class="text-xs sm:text-sm text-gray-500 ml-6">{{ reservation.user.email }}</div>
                </div>
                
                <!-- Reference -->
                <h3 class="font-bold text-base sm:text-lg text-noz-blue mb-2">{{ reservation.reference }}</h3>
                
                <!-- Items List -->
                <div class="mb-3 bg-gray-50 p-2 rounded">
                    <ul class="text-sm space-y-1">
                        {% for item in reservation.reservationItems %}
                            <li class="flex justify-between">
                                <span>{{ item.product.name }}</span>
                                <span class="font-bold">x{{ item.quantity }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>

                {% if reservation.comment %}
                    <div class="mb-3 text-xs text-gray-600 italic border-l-2 border-yellow-400 bg-yellow-50 p-2 rounded">
                        <span class="font-bold">Note:</span> {{ reservation.comment }}
                    </div>
                {% endif %}
                
                <!-- Details -->
                <div class="space-y-1 sm:space-y-2 text-xs sm:text-sm mb-3 sm:mb-4">
                    <div class="flex justify-between">
                        <span class="text-gray-600">Réservé le:</span>
                        <span class="font-semibold text-right">{{ reservation.reservedAt|date('d/m/Y à H:i') }}</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600">Expire le:</span>
                        <div class="text-right">
                            {% if isExpired %}
                                <span class="font-bold text-red-600">Expirée !</span>
                            {% else %}
                                <span class="font-semibold {% if isUrgent %}text-orange-600{% else %}text-green-600{% endif %}">
                                    {{ reservation.expiresAt|date('d/m/Y à H:i') }}
                                </span>
                                {% if isUrgent %}
                                    <div class="text-xs text-orange-600 font-medium">⚠️ Expire bientôt</div>
                                {% endif %}
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <!-- Action button -->
                <form action="{{ path('app_reservation_collect', {'id': reservation.id}) }}" method="post">
                    <button type="submit" class="w-full bg-green-500 hover:bg-green-600 text-white py-2 px-4 rounded font-medium text-sm flex items-center justify-center gap-2">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Marquer comme récupéré
                    </button>
                </form>
            </div>
        {% else %}
            <div class="bg-white rounded-lg shadow-md p-8 text-center text-gray-500">
                <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                <p class="text-lg font-medium">Aucune réservation active</p>
                <p class="text-sm mt-2">Toutes les réservations ont été récupérées ou expirées</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
