{% extends 'base.html.twig' %}

{% block title %}Gestion des Produits{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    {% include 'components/_breadcrumb.html.twig' with {
        'breadcrumbs': [
            {'label': 'Gestion Produits', 'url': null}
        ]
    } %}
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 sm:gap-0 mb-6">
        <h1 class="text-2xl sm:text-3xl font-bold text-noz-blue">Gestion des Produits</h1>
        <a href="{{ path('app_product_new') }}" class="w-full sm:w-auto bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-4 rounded text-center text-sm sm:text-base">
            + Nouveau Produit
        </a>
    </div>

    <!-- Desktop: Table view (hidden on mobile) -->
    <div class="hidden lg:block bg-white shadow-md rounded my-6">
        <div class="overflow-x-auto">
        <table class="min-w-full table-auto">
            <thead>
                <tr class="bg-gray-200 text-gray-600 uppercase text-sm leading-normal">
                    <th scope="col" class="py-3 px-6 text-left">Image</th>
                    <th scope="col" class="py-3 px-6 text-left">Nom</th>
                    <th scope="col" class="py-3 px-6 text-center">Prix</th>
                    <th scope="col" class="py-3 px-6 text-center">Prix Origine</th>
                    <th scope="col" class="py-3 px-6 text-center">Catégorie</th>
                    <th scope="col" class="py-3 px-6 text-center">Stock</th>
                    <th scope="col" class="py-3 px-6 text-center">Créé par</th>
                    <th scope="col" class="py-3 px-6 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="text-gray-600 text-sm font-light">
                {% for product in products %}
                    <tr class="border-b border-gray-200 hover:bg-gray-100">
                        <td class="py-3 px-6 text-left">
                            {% if product.imageFilename %}
                                <img src="{{ asset('uploads/images/' ~ product.imageFilename) }}" alt="{{ product.name }}" class="w-16 h-16 object-cover rounded">
                            {% else %}
                                <img src="{{ asset('uploads/images/placeholder.svg') }}" alt="Pas d'image" class="w-16 h-16 object-contain rounded bg-gray-100">
                            {% endif %}
                        </td>
                        <td class="py-3 px-6 text-left whitespace-nowrap">
                            <span class="font-medium">{{ product.name }}</span>
                        </td>
                        <td class="py-3 px-6 text-center">
                            <span class="font-bold text-noz-red">{{ product.price }} €</span>
                        </td>
                        <td class="py-3 px-6 text-center">
                            {% if product.originalPrice %}
                                <span class="text-gray-500 line-through">{{ product.originalPrice }} €</span>
                            {% else %}
                                <span class="text-gray-400">-</span>
                            {% endif %}
                        </td>
                        <td class="py-3 px-6 text-center">
                            {% if product.category %}
                                <span class="bg-blue-50 text-noz-blue px-2 py-1 rounded text-xs font-bold">{{ product.category.name }}</span>
                            {% else %}
                                <span class="text-gray-400 italic">Sans catégorie</span>
                            {% endif %}
                        </td>
                        <td class="py-3 px-6 text-center">
                            <span class="{% if product.stock > 0 %}text-green-600{% else %}text-red-600{% endif %} font-semibold">
                                {{ product.stock }}
                            </span>
                        </td>
                        <td class="py-3 px-6 text-center">
                            {% if product.createdBy %}
                                <span class="text-xs bg-blue-100 text-blue-800 py-1 px-2 rounded-full">
                                    {% if product.createdBy.firstName or product.createdBy.lastName %}
                                        {{ product.createdBy.firstName }} {{ product.createdBy.lastName }}
                                    {% else %}
                                        {{ product.createdBy.email }}
                                    {% endif %}
                                </span>
                            {% else %}
                                <span class="text-xs text-gray-400">Inconnu</span>
                            {% endif %}
                        </td>
                         <td class="py-3 px-6 text-center">
                            <div class="flex item-center justify-center gap-3">
                                <a href="{{ path('app_product_show', {'id': product.id}) }}" class="text-blue-500 hover:text-blue-700" aria-label="Voir le produit {{ product.name }}">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </a>
                                <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="text-green-500 hover:text-green-700" aria-label="Modifier le produit {{ product.name }}">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <button onclick="openDeleteModal({{ product.id }}, '{{ product.name|e('js') }}', '{{ csrf_token('delete' ~ product.id) }}')" class="text-red-500 hover:text-red-700" aria-label="Supprimer le produit {{ product.name }}">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="py-3 px-6 text-center">Aucun produit trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>

    <!-- Mobile/Tablet: Card view (hidden on desktop) -->
    <div class="lg:hidden space-y-4">
        {% for product in products %}
            <div class="bg-white rounded-lg shadow-md overflow-hidden">
                <!-- Horizontal layout for screens >= 450px, vertical for smaller -->
                <div class="flex flex-col xs:flex-row">
                    <!-- Image -->
                    <div class="w-full xs:w-24 sm:w-32 h-32 xs:h-24 sm:h-32 flex-shrink-0">
                        {% if product.imageFilename %}
                            <img src="{{ asset('uploads/images/' ~ product.imageFilename) }}" alt="{{ product.name }}" class="w-full h-full object-cover">
                        {% else %}
                            <img src="{{ asset('uploads/images/placeholder.svg') }}" alt="Pas d'image" class="w-full h-full object-contain bg-gray-100">
                        {% endif %}
                    </div>
                    
                    <!-- Content -->
                    <div class="flex-1 p-3 sm:p-4">
                        <h3 class="font-bold text-base sm:text-lg text-noz-blue mb-2 line-clamp-2">{{ product.name }}</h3>
                        
                        <div class="space-y-1 sm:space-y-2 text-xs sm:text-sm mb-3">
                            <div class="flex justify-between items-center">
                                <span class="text-gray-600">Prix:</span>
                                <span class="font-bold text-noz-red text-base sm:text-lg">{{ product.price }} €</span>
                            </div>
                            
                            <div class="flex justify-between items-center">
                                <span class="text-gray-600">Catégorie:</span>
                                <span class="font-medium text-noz-blue">{% if product.category %}{{ product.category.name }}{% else %}-{% endif %}</span>
                            </div>

                            <div class="flex justify-between items-center">
                                <span class="text-gray-600">Stock:</span>
                                <span class="{% if product.stock > 0 %}text-green-600{% else %}text-red-600{% endif %} font-semibold">
                                    {{ product.stock }}
                                </span>
                            </div>
                        </div>
                        
                        <!-- Actions - Stack on very small screens -->
                        <div class="flex flex-col xs:flex-row gap-2">
                            <a href="{{ path('app_product_show', {'id': product.id}) }}" 
                               class="flex-1 bg-blue-500 hover:bg-blue-600 text-white text-center py-1.5 sm:py-2 px-2 sm:px-3 rounded text-xs sm:text-sm font-medium">
                                Voir
                            </a>
                            <a href="{{ path('app_product_edit', {'id': product.id}) }}" 
                               class="flex-1 bg-green-500 hover:bg-green-600 text-white text-center py-1.5 sm:py-2 px-2 sm:px-3 rounded text-xs sm:text-sm font-medium">
                                Modifier
                            </a>
                            <button onclick="openDeleteModal({{ product.id }}, '{{ product.name|e('js') }}', '{{ csrf_token('delete' ~ product.id) }}')" 
                                    class="flex-1 bg-red-500 hover:bg-red-600 text-white py-1.5 sm:py-2 px-2 sm:px-3 rounded text-xs sm:text-sm font-medium">
                                Supprimer
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="bg-white rounded-lg shadow-md p-8 text-center text-gray-500">
                <p class="text-lg">Aucun produit trouvé.</p>
            </div>
        {% endfor %}
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
    <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
        <div class="mt-3 text-center">
            <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100">
                <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </div>
            <h3 class="text-lg leading-6 font-medium text-gray-900 mt-5">Supprimer le produit</h3>
            <div class="mt-2 px-7 py-3">
                <p class="text-sm text-gray-500" id="deleteModalText">
                    Êtes-vous sûr de vouloir supprimer ce produit ?
                </p>
            </div>
            <div class="items-center px-4 py-3">
                <form id="deleteForm" method="post" class="inline">
                    <input type="hidden" name="_token" id="deleteFormToken">
                    <button type="submit" class="px-4 py-2 bg-red-500 text-white text-base font-medium rounded-md w-24 mr-2 hover:bg-red-600">
                        Supprimer
                    </button>
                </form>
                <button onclick="closeDeleteModal()" class="px-4 py-2 bg-gray-500 text-white text-base font-medium rounded-md w-24 hover:bg-gray-600">
                    Annuler
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function openDeleteModal(productId, productName, csrfToken) {
        document.getElementById('deleteModalText').textContent = `Êtes-vous sûr de vouloir supprimer le produit "${productName}" ?`;
        document.getElementById('deleteForm').action = `/product/${productId}`;
        document.getElementById('deleteFormToken').value = csrfToken;
        document.getElementById('deleteModal').classList.remove('hidden');
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.add('hidden');
    }

    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
            closeDeleteModal();
        }
    });
</script>
{% endblock %}
