{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8 text-noz-blue">Mon Panier</h1>

    {% if cart|length > 0 %}
        <div class="bg-white rounded-lg shadow-md overflow-hidden mb-8">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Produit</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Prix</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Quantité</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for item in cart %}
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    {% if item.product.imageFilename %}
                                        <img class="h-10 w-10 rounded-full object-cover mr-4" src="{{ asset('uploads/images/' ~ item.product.imageFilename) }}" alt="{{ item.product.name }}">
                                    {% else %}
                                        <div class="h-10 w-10 rounded-full bg-gray-200 mr-4 flex items-center justify-center text-gray-500">
                                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                    {% endif %}
                                    <div class="text-sm font-medium text-gray-900">{{ item.product.name }}</div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {{ item.product.price }} €
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center text-sm text-gray-500">
                                <div class="flex justify-center items-center space-x-2">
                                    <a href="{{ path('app_cart_decrease', {'id': item.product.id}) }}" class="text-gray-500 hover:text-red-600 font-bold px-2 border rounded">-</a>
                                    <span>{{ item.quantity }}</span>
                                    <form action="{{ path('app_cart_add', {'id': item.product.id}) }}" method="post" class="inline">
                                        <input type="hidden" name="returnToCart" value="1">
                                        <button type="submit" class="text-gray-500 hover:text-green-600 font-bold px-2 border rounded">+</button>
                                    </form>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold text-gray-900">
                                {{ item.product.price * item.quantity }} €
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="{{ path('app_cart_remove', {'id': item.product.id}) }}" class="text-red-600 hover:text-red-900">Supprimer</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot class="bg-gray-50">
                    <tr>
                        <td colspan="3" class="px-6 py-4 text-right font-bold text-gray-900">Total</td>
                        <td class="px-6 py-4 text-right font-bold text-xl text-noz-red">{{ total }} €</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-xl font-bold mb-4 text-noz-blue">Finaliser ma réservation</h2>
            
            <form action="{{ path('app_reservation_validate') }}" method="post">
                <div class="mb-4">
                    <label for="comment" class="block text-gray-700 text-sm font-bold mb-2">Commentaire (optionnel)</label>
                    <textarea name="comment" id="comment" rows="3" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" placeholder="Précisions sur votre commande (ex: pointure, couleur préférée...)"></textarea>
                </div>

                <div class="flex justify-end gap-4">
                    <a href="{{ path('app_home') }}" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-6 rounded">
                        Continuer mes achats
                    </a>
                    <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-6 rounded">
                        Valider la réservation
                    </button>
                </div>
            </form>
        </div>

    {% else %}
        <div class="text-center py-12 bg-white rounded-lg shadow-md">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Votre panier est vide</h3>
            <p class="mt-1 text-sm text-gray-500">Commencez par ajouter des produits.</p>
            <div class="mt-6">
                <a href="{{ path('app_home') }}" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-noz-btn hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Voir les produits
                </a>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
