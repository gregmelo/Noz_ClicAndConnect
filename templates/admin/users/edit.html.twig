{% extends 'base.html.twig' %}

{% block title %}Modifier Utilisateur{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-noz-blue">Modifier l'utilisateur</h1>
            <a href="{{ path('app_admin_users_index') }}" class="text-gray-600 hover:text-gray-800">
                ← Retour
            </a>
        </div>

        <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
            <form method="post" class="space-y-6">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_edit') }}">
                <div>
                    <label for="email" class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                    <input type="email" id="email" name="email" value="{{ user.email }}" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="firstName" class="block text-gray-700 text-sm font-bold mb-2">Prénom</label>
                        <input type="text" id="firstName" name="firstName" value="{{ user.firstName }}" required
                               class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    </div>

                    <div>
                        <label for="lastName" class="block text-gray-700 text-sm font-bold mb-2">Nom</label>
                        <input type="text" id="lastName" name="lastName" value="{{ user.lastName }}" required
                               class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    </div>
                </div>

                <div>
                    <label for="role" class="block text-gray-700 text-sm font-bold mb-2">Rôle</label>
                    <select id="role" name="role" required
                            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                        {% for role in allowedRoles %}
                            <option value="{{ role }}" {% if role in user.roles %}selected{% endif %}>
                                {% if role == 'ROLE_DEVELOPER' %}Développeur
                                {% elseif role == 'ROLE_SUPER_WARRIOR' %}Super Warrior
                                {% elseif role == 'ROLE_WARRIOR' %}Warrior
                                {% elseif role == 'ROLE_WARRIOR_JUNIOR' %}Warrior junior
                                {% else %}Client
                                {% endif %}
                            </option>
                        {% endfor %}
                    </select>
                    <div id="role-description-box" class="mt-2 p-3 bg-blue-50 border-l-4 border-blue-400 rounded text-sm text-blue-700 italic">
                        Chargement de la description...
                    </div>
                </div>

                <script>
                    (function() {
                        function initRoleDescription() {
                            const roleSelect = document.getElementById('role');
                            const descriptionBox = document.getElementById('role-description-box');
                            if (!roleSelect || !descriptionBox) return;
                            
                            const descriptions = {
                                'ROLE_CLIENT': "Accès standard. Peut parcourir les produits, gérer son panier et ses réservations.",
                                'ROLE_WARRIOR_JUNIOR': "Accès magasin. Peut gérer les stocks, préparer les commandes (picking) et valider les retraits clients.",
                                'ROLE_WARRIOR': "Accès gestion. Peut gérer les utilisateurs (Client/Employé), les catégories et consulter les logs d'audit.",
                                'ROLE_SUPER_WARRIOR': "Accès total (sauf technique). Peut gérer tous les niveaux d'utilisateurs et les paramètres critiques.",
                                'ROLE_DEVELOPER': "Accès technique complet. Accès à tous les outils de maintenance, y compris la base de données."
                            };

                            function updateDescription() {
                                const role = roleSelect.value;
                                const text = descriptions[role] || "Aucune description disponible pour ce rôle.";
                                descriptionBox.innerHTML = `
                                    <div class="flex items-start gap-2">
                                        <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                        <span>${text}</span>
                                    </div>
                                `;
                            }

                            // Remove old listener if any and add new one
                            roleSelect.removeEventListener('change', updateDescription);
                            roleSelect.addEventListener('change', updateDescription);
                            updateDescription();
                        }

                        // Support Turbo and Standard loads
                        document.addEventListener('turbo:load', initRoleDescription);
                        // Also run immediately in case turbo:load already fired or is not used
                        initRoleDescription();
                    })();
                </script>

                <div>
                    <label for="strikes" class="block text-gray-700 text-sm font-bold mb-2">Nombre de Strikes</label>
                    <input type="number" id="strikes" name="strikes" value="{{ user.strikes }}" min="0" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <p class="text-xs text-gray-500 mt-1">3 strikes = Bannissement automatique.</p>
                </div>

                <div class="flex items-center justify-between pt-4">
                    <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline">
                        Modifier
                    </button>
                    <a href="{{ path('app_admin_users_index') }}" class="text-gray-600 hover:text-gray-800">
                        Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
