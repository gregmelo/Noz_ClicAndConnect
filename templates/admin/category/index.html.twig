{% extends 'base.html.twig' %}

{% block title %}Gestion des Catégories{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-noz-blue">Gestion des Catégories</h1>
        <a href="{{ path('app_admin_category_new') }}" class="bg-noz-btn text-white px-4 py-2 rounded shadow hover:bg-blue-700 transition">
            ➕ Nouvelle Catégorie
        </a>
    </div>

    <div class="bg-white shadow-md rounded overflow-hidden">
        <table class="min-w-full table-auto">
            <thead>
                <tr class="bg-gray-200 text-gray-600 uppercase text-sm leading-normal">
                    <th class="py-3 px-6 text-left">ID</th>
                    <th class="py-3 px-6 text-left">Nom</th>
                    <th class="py-3 px-6 text-center">Produits</th>
                    <th class="py-3 px-6 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="text-gray-600 text-sm font-light">
                {% for category in categories %}
                    <tr class="border-b border-gray-200 hover:bg-gray-100">
                        <td class="py-3 px-6 text-left whitespace-nowrap">{{ category.id }}</td>
                        <td class="py-3 px-6 text-left font-bold">{{ category.name }}</td>
                        <td class="py-3 px-6 text-center">{{ category.products|length }}</td>
                        <td class="py-3 px-6 text-center">
                            <div class="flex item-center justify-center gap-4">
                                <a href="{{ path('app_admin_category_edit', {'id': category.id}) }}" class="text-blue-500 hover:text-blue-700" title="Modifier">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                </a>
                                <form method="post" action="{{ path('app_admin_category_delete', {'id': category.id}) }}" onsubmit="return confirm('Supprimer cette catégorie ?');" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                    <button class="text-red-500 hover:text-red-700">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="py-6 text-center text-gray-400 italic">Aucune catégorie trouvée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="mt-8">
        <a href="{{ path('app_product_index') }}" class="text-noz-blue hover:underline">← Retour à la liste des produits</a>
    </div>
</div>
{% endblock %}
