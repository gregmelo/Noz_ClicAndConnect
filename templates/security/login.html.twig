{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <form method="post" action="{{ path('app_login') }}"class="max-w-md mx-auto bg-white p-8 border rounded shadow-md" aria-label="Formulaire de connexion">
        {% if error %}
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                Vous êtes connecté en tant que {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Déconnexion</a>
            </div>
        {% endif %}

        <h1 class="h3 mb-3 font-weight-normal text-2xl font-bold mb-6 text-center">Connexion</h1>
        
        <div class="mb-4">
            <label for="inputEmail" class="block text-gray-700 text-sm font-bold mb-2">Email</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" autocomplete="email" required autofocus>
        </div>
        
        <div class="mb-6">
            <label for="inputPassword" class="block text-gray-700 text-sm font-bold mb-2">Mot de passe</label>
            <div class="flex items-center shadow border rounded bg-white focus-within:shadow-outline mb-3">
                <input type="password" name="password" id="inputPassword" class="flex-1 py-2 px-3 appearance-none text-gray-700 leading-tight focus:outline-none bg-transparent border-0 outline-none" autocomplete="current-password" required>
                <button type="button" onclick="togglePassword(this)" class="flex-shrink-0 px-3 text-gray-400 hover:text-gray-700 focus:outline-none" aria-label="Afficher/masquer le mot de passe" tabindex="-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                </button>
            </div>
            <div class="text-right">
                <a href="{{ path('app_forgot_password_request') }}" class="text-sm text-blue-500 hover:text-blue-800">Mot de passe oublié ?</a>
            </div>
        </div>

        <input type="hidden" name="_csrf_token"
               value="{{ csrf_token('authenticate') }}"
        >

        <div class="flex items-center justify-between">
            <button class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline w-full" type="submit">
                Se connecter
            </button>
        </div>
        
        <div class="mt-4 text-center">
            <a href="{{ path('app_register') }}" class="text-sm text-blue-500 hover:text-blue-800">Pas encore de compte ? S'inscrire</a>
        </div>
    </form>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function togglePassword(btn) {
    const input = btn.parentElement.querySelector('input');
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    btn.setAttribute('aria-label', isHidden ? 'Masquer le mot de passe' : 'Afficher le mot de passe');
    btn.innerHTML = isHidden
        ? '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>'
        : '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>';
}
</script>
{% endblock %}
