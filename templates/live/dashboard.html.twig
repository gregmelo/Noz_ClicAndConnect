{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord Live - Noz ClicAndConnect{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto" data-controller="live">
    {# Programmation du prochain live #}
    <div class="mb-6 bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex flex-col gap-3">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
            <div>
                <h2 class="text-lg font-bold text-noz-blue">Programmation du prochain live</h2>
                {% if nextLiveAt %}
                    <p class="text-sm text-gray-600 mt-1">
                        Actuellement programmé le <span class="font-semibold">{{ nextLiveAt|date('d/m/Y') }}</span>
                        à <span class="font-semibold">{{ nextLiveAt|date('H:i') }}</span>.
                    </p>
                {% else %}
                    <p class="text-sm text-gray-600 mt-1 italic">Aucun live n'est programmé pour le moment.</p>
                {% endif %}
            </div>
        </div>
        <form action="{{ path('app_live_schedule') }}" method="post" class="flex flex-col md:flex-row gap-3 md:items-end">
            <input type="hidden" name="_token" value="{{ csrf_token('schedule_next_live') }}">
            <div>
                <label for="next_live_date" class="block text-xs font-semibold text-gray-700 mb-1">Date</label>
                <input type="date" id="next_live_date" name="next_live_date" value="{{ nextLiveAt ? nextLiveAt|date('Y-m-d') : '' }}" class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-noz-blue focus:border-noz-blue bg-white">
            </div>
            <div>
                <label for="next_live_time" class="block text-xs font-semibold text-gray-700 mb-1">Heure</label>
                <input type="text" id="next_live_time" name="next_live_time" value="{{ nextLiveAt ? nextLiveAt|date('H:i') : '' }}" class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-noz-blue focus:border-noz-blue bg-white w-24" placeholder="HH:mm" maxlength="5">
            </div>
            <div class="flex gap-2 mt-2 md:mt-0">
                <button type="submit" name="action" value="set" class="bg-noz-blue hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-md">Enregistrer</button>
                {% if nextLiveAt %}
                    <button type="submit" name="action" value="clear" class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-sm font-semibold px-4 py-2 rounded-md">Annuler la programmation</button>
                {% endif %}
            </div>
        </form>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-3xl font-extrabold text-noz-blue">
            <span class="inline-block w-3 h-3 bg-red-600 rounded-full animate-pulse mr-2"></span>
            Session Live Shopping
        </h1>
        <div class="text-sm bg-blue-50 text-blue-800 px-4 py-2 rounded-lg border border-blue-100 italic">
            Activez les produits au fur et à mesure de votre présentation.
        </div>
    </div>

    {# Search / Filters #}
    <div class="bg-white p-4 rounded-xl shadow-sm mb-6 border border-gray-100">
        <input type="text" 
               placeholder="Rechercher un produit..." 
               class="w-full px-4 py-3 rounded-lg border-gray-200 focus:ring-noz-blue focus:border-noz-blue search-input"
               onkeyup="let term = this.value.toLowerCase(); document.querySelectorAll('.product-row').forEach(row => { row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none' })">
    </div>

    <div class="space-y-4">
        {% for product in products %}
            <div class="product-row bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden transition-colors duration-300 {{ product.isLive ? 'bg-green-50 border-green-200' : '' }}" 
                 data-product-id="{{ product.id }}">
                <div class="p-4 flex items-center gap-4">
                    {# Thumbnail #}
                    <div class="w-20 h-20 flex-shrink-0 bg-gray-50 rounded-lg overflow-hidden border border-gray-100">
                        {% if product.imageFilename %}
                            <img src="{{ asset('uploads/images/' ~ product.imageFilename) }}" alt="{{ product.name }}" class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-300">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                            </div>
                        {% endif %}
                    </div>

                    {# Info #}
                    <div class="flex-grow min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                            <h2 class="text-lg font-bold text-gray-900 truncate">{{ product.name }}</h2>
                            <span data-live-target="status" class="px-2 py-0.5 text-xs font-semibold rounded-full {{ product.isLive ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' }}">
                                {{ product.isLive ? 'En ligne' : 'Hors ligne' }}
                            </span>
                        </div>
                        <p class="text-sm text-gray-500 mb-2 truncate">{{ product.category ? product.category.name : 'Sans catégorie' }}</p>
                        <div class="flex items-center gap-4">
                            <span class="text-noz-blue font-bold">{{ product.price|number_format(2, ',', ' ') }} €</span>
                            <span class="text-sm {{ product.stock <= 5 ? 'text-red-600 font-bold' : 'text-gray-600' }}">
                                Stock: {{ product.stock }}
                            </span>
                        </div>
                    </div>

                    {# Actions : interrupteur ON/OFF (switch style OS avec marge à gauche) #}
                    <div class="flex-shrink-0 flex items-center gap-2 live-switch-wrapper">
                        <label class="live-switch-container cursor-pointer select-none">
                            <input type="checkbox"
                                   class="live-switch-input"
                                   data-live-toggle="1"
                                   data-product-id="{{ product.id }}"
                                   data-activate-url="{{ path('app_live_product_activate', {id: product.id}) }}"
                                   data-deactivate-url="{{ path('app_live_product_deactivate', {id: product.id}) }}"
                                   data-activate-token="{{ csrf_token('live_activate_' ~ product.id) }}"
                                   data-deactivate-token="{{ csrf_token('live_deactivate_' ~ product.id) }}"
                                   {% if product.isLive %}checked{% endif %}>
                            <span class="live-slider round"></span>
                        </label>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center py-12 bg-white rounded-xl shadow-sm border border-dashed border-gray-300">
                <p class="text-gray-500">Aucun produit trouvé dans le catalogue.</p>
                <a href="{{ path('app_product_new') }}" class="mt-4 inline-block text-noz-blue hover:underline">Créer un premier produit</a>
            </div>
        {% endfor %}
    </div>
</div>
<style>
.live-switch-wrapper {
    margin-left: 50px;
}

.live-switch-container {
    display: inline-grid;
    grid-template-columns: auto;
    align-items: center;
}

.live-switch-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
}

.live-switch-input:focus + .live-slider.round {
    outline: 3px solid #ff9800;
    outline-offset: 2px;
}

.live-slider.round {
    display: inline-block;
    width: 55px;
    height: 32px;
    background-color: #ffffff;
    border: 2px solid #0078d7;
    border-radius: 9999px;
    position: relative;
    cursor: pointer;
}

.live-slider.round::before {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    background-color: #0078d7;
    border-radius: 50%;
    top: 4px;
    left: 8px;
    transition: all 0.3s;
}

.live-switch-input:checked + .live-slider.round {
    background-color: #dcfce7; /* vert pâle comme le fond du badge "En ligne" (bg-green-100) */
    border-color: #dcfce7; /* léger contraste pour le contour */
}

.live-switch-input:checked + .live-slider.round::before {
    transform: translateX(18px);
}
</style>
<script>
// Initialisation des interrupteurs live (compatible DOMContentLoaded + Turbo)
function initLiveToggles() {
    document.querySelectorAll('input[type="checkbox"][data-live-toggle]')
        .forEach(function (checkbox) {
            if (checkbox.dataset.liveToggleBound === '1') {
                return;
            }
            checkbox.dataset.liveToggleBound = '1';

            checkbox.addEventListener('change', async function (event) {
                const cb = event.currentTarget;
                const productId = cb.dataset.productId;
                const url = cb.checked ? cb.dataset.activateUrl : cb.dataset.deactivateUrl;
                const token = cb.checked ? cb.dataset.activateToken : cb.dataset.deactivateToken;

                cb.disabled = true;

                try {
                    const formData = new FormData();
                    formData.append('_token', token);

                    const response = await fetch(url, {
                        method: 'POST',
                        body: formData,
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    const result = await response.json();

                    if (result.success) {
                        updateLiveRowUI(productId, cb.checked);
                        showLiveToast(result.message, 'success');
                    } else {
                        showLiveToast(result.error || 'Une erreur est survenue.', 'error');
                        cb.checked = !cb.checked;
                    }
                } catch (e) {
                    console.error(e);
                    showLiveToast('Erreur de connexion au serveur.', 'error');
                    cb.checked = !cb.checked;
                } finally {
                    cb.disabled = false;
                }
            });
        });
}

// Gestion simple des toggles live sans dépendre de Stimulus, avec support Turbo
document.addEventListener('DOMContentLoaded', initLiveToggles);
document.addEventListener('turbo:load', initLiveToggles);

function updateLiveRowUI(productId, isActive) {
    const row = document.querySelector('[data-product-id="' + productId + '"]');
    if (!row) return;

    const statusBadge = row.querySelector('[data-live-target="status"]');
    if (statusBadge) {
        if (isActive) {
            statusBadge.textContent = 'En ligne';
            statusBadge.classList.remove('bg-gray-100', 'text-gray-800');
            statusBadge.classList.add('bg-green-100', 'text-green-800');
        } else {
            statusBadge.textContent = 'Hors ligne';
            statusBadge.classList.remove('bg-green-100', 'text-green-800');
            statusBadge.classList.add('bg-gray-100', 'text-gray-800');
        }
    }

    if (isActive) {
        row.classList.add('bg-green-50', 'border-green-200');
    } else {
        row.classList.remove('bg-green-50', 'border-green-200');
    }
}

function showLiveToast(message, type) {
    const toast = document.createElement('div');
    toast.textContent = message;

    toast.style.position = 'fixed';
    toast.style.bottom = '3rem'; // ~bottom-6
    toast.style.right = '1.5rem';  // ~right-6
    toast.style.maxWidth = '320px';
    toast.style.padding = '0.5rem 0.75rem';
    toast.style.borderRadius = '0.375rem';
    toast.style.boxShadow = '0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)';
    toast.style.fontSize = '0.875rem';
    toast.style.color = '#ffffff';
    toast.style.zIndex = '9999';
    toast.style.backgroundColor = (type === 'success') ? '#15803d' : '#b91c1c';
    toast.style.transform = 'translateY(10px)';
    toast.style.opacity = '0';
    toast.style.transition = 'all 0.3s ease';

    document.body.appendChild(toast);

    requestAnimationFrame(function () {
        toast.style.transform = 'translateY(0)';
        toast.style.opacity = '1';
    });

    setTimeout(function () {
        toast.style.transform = 'translateY(10px)';
        toast.style.opacity = '0';
        setTimeout(function () { toast.remove(); }, 300);
    }, 3000);

    // Gestion de la saisie intuitive de l'heure (auto-colon)
    const timeInput = document.getElementById('next_live_time');
    if (timeInput) {
        timeInput.oninput = function() {
            let val = this.value.replace(/[^0-9]/g, '');
            if (val.length >= 2) {
                this.value = val.slice(0, 2) + ':' + val.slice(2, 4);
            } else {
                this.value = val;
            }
        };
    }
}
</script>
{% endblock %}
