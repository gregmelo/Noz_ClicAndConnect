{% extends 'base.html.twig' %}

{% block title %}Erreur Serveur{% endblock %}

{% block body %}
<div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <div class="text-noz-red mb-4">
        <svg class="w-24 h-24 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
    </div>
    <h1 class="text-4xl font-bold text-gray-800 mb-2">500</h1>
    <h2 class="text-2xl font-semibold text-gray-600 mb-6">Un pépin technique !</h2>
    <p class="text-gray-500 mb-8 max-w-md">
        Oups ! Une erreur inattendue s'est produite. L'équipe technique de NOZ AMBERIEU a été alertée. 
        Veuillez réessayer dans quelques instants.
    </p>
    <a href="{{ path('app_home') }}" class="bg-noz-btn text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition duration-300 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Retour au bercail
    </a>
</div>
{% endblock %}
