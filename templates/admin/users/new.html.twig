{% extends 'base.html.twig' %}

{% block title %}Nouvel Utilisateur{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold text-noz-blue">Créer un utilisateur</h1>
            <a href="{{ path('app_admin_users_index') }}" class="text-gray-600 hover:text-gray-800">
                ← Retour
            </a>
        </div>

        <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
            <form method="post" class="space-y-6">
                <div>
                    <label for="email" class="block text-gray-700 text-sm font-bold mb-2">Email</label>
                    <input type="email" id="email" name="email" required
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="firstName" class="block text-gray-700 text-sm font-bold mb-2">Prénom</label>
                        <input type="text" id="firstName" name="firstName" required
                               class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    </div>

                    <div>
                        <label for="lastName" class="block text-gray-700 text-sm font-bold mb-2">Nom</label>
                        <input type="text" id="lastName" name="lastName" required
                               class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-gray-700 text-sm font-bold mb-2">Mot de passe</label>
                    <input type="password" id="password" name="password" required minlength="6"
                           class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                    <p class="text-xs text-gray-500 mt-1">Minimum 6 caractères</p>
                </div>

                <div>
                    <label for="role" class="block text-gray-700 text-sm font-bold mb-2">Rôle</label>
                    <select id="role" name="role" required
                            class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                        {% for role in allowedRoles %}
                            <option value="{{ role }}">
                                {% if role == 'ROLE_DEVELOPER' %}Développeur
                                {% elseif role == 'ROLE_SUPER_ADMIN' %}Super Admin
                                {% elseif role == 'ROLE_ADMIN' %}Admin
                                {% elseif role == 'ROLE_EMPLOYEE' %}Employé
                                {% else %}Client
                                {% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="flex items-center justify-between pt-4">
                    <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-6 rounded focus:outline-none focus:shadow-outline">
                        Créer
                    </button>
                    <a href="{{ path('app_admin_users_index') }}" class="text-gray-600 hover:text-gray-800">
                        Annuler
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
