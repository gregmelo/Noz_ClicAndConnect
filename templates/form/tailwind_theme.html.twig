{% use 'form_div_layout.html.twig' %}

{% block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul class="text-red-500 text-xs italic mt-1 list-none ml-0 pl-0">
            {%- for error in errors -%}
                <li>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{%- endblock form_errors %}
