{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-md mx-auto">
        <div class="bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
            <h1 class="text-3xl font-bold mb-6 text-center text-noz-blue">Inscription</h1>

            {{ form_start(registrationForm, {'attr': {'class': 'space-y-6', 'aria-label': 'Formulaire d\'inscription'}}) }}
                
                <div>
                    {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(registrationForm.firstName, 'Prénom', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
                        {{ form_widget(registrationForm.firstName, {'attr': {'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                        {{ form_errors(registrationForm.firstName) }}
                    </div>

                    <div>
                        {{ form_label(registrationForm.lastName, 'Nom', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
                        {{ form_widget(registrationForm.lastName, {'attr': {'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline'}}) }}
                        {{ form_errors(registrationForm.lastName) }}
                    </div>
                </div>

                <div>
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {
                        'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline',
                        'aria-describedby': 'password-help'
                    }}) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                    <p id="password-help" class="text-xs text-gray-500 mt-1">Minimum 12 caractères, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial</p>
                </div>

                <div class="flex items-start bg-blue-50 p-4 rounded-xl border border-blue-100">
                    <div class="flex items-center h-5">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 text-noz-blue bg-white border-gray-300 rounded focus:ring-noz-blue focus:ring-2'}}) }}
                    </div>
                    <div class="ml-3 text-sm">
                        <label for="{{ registrationForm.agreeTerms.vars.id }}" class="font-medium text-gray-700 leading-snug">
                            J'ai lu et j'accepte les <a href="{{ path('app_cgv') }}" class="text-noz-blue font-bold hover:underline" target="_blank">Conditions Générales de Vente</a> 
                            ainsi que la <a href="{{ path('app_privacy') }}" class="text-noz-blue font-bold hover:underline" target="_blank">Politique de Confidentialité</a>.
                        </label>
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" class="w-full bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">
                        S'inscrire
                    </button>
                </div>

                <div class="text-center mt-4">
                    <a href="{{ path('app_login') }}" class="text-sm text-blue-500 hover:text-blue-800">
                        Déjà un compte ? Se connecter
                    </a>
                </div>

            {{ form_end(registrationForm) }}
        </div>
    </div>
</div>
{% endblock %}
