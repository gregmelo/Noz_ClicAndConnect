{% extends 'base.html.twig' %}

{% block title %}Noz ClicAndConnect - Amberieu-en-Bugey{% endblock %}
{% block meta_description %}Découvrez les derniers arrivages NOZ à Amberieu-en-Bugey. Réservez vos articles en ligne via notre Clic & Collect et profitez des meilleures affaires.{% endblock %}


{% block body %}
<div class="container mx-auto px-4 py-8">
    {# Bandeau d'installation PWA - seulement si le navigateur propose l'installation #}
    <div
        data-controller="pwa-install"
        class="hidden fixed bottom-4 inset-x-4 z-40 bg-noz-blue text-white px-4 py-3 rounded-2xl shadow-2xl flex flex-col sm:flex-row sm:items-center gap-3 border border-noz-yellow/60 max-w-3xl mx-auto"
        role="status"
        aria-live="polite"
    >
        <div class="flex items-start gap-3 flex-1">
            <div class="mt-0.5 flex-shrink-0">
                <span class="relative flex h-4 w-4">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-noz-yellow opacity-80"></span>
                    <span class="relative inline-flex rounded-full h-4 w-4 bg-noz-yellow"></span>
                </span>
            </div>
            <div>
                <p class="text-sm font-semibold tracking-wide uppercase">Installez Noz ClicAndConnect</p>
                <p class="text-xs text-noz-yellow/80 mt-0.5">
                    Ajoutez l'application à votre écran d'accueil pour un accès ultra rapide à vos arrivages et réservations.
                </p>
            </div>
        </div>
        <div class="flex items-center gap-2 justify-end">
            <button
                type="button"
                class="text-xs px-3 py-2 rounded-lg bg-white/10 hover:bg-white/20 transition font-medium"
                data-action="click->pwa-install#dismiss"
            >
                Plus tard
            </button>
            <button
                type="button"
                class="text-xs px-4 py-2 rounded-lg bg-noz-yellow text-noz-blue font-bold shadow hover:bg-yellow-300 transition"
                data-action="click->pwa-install#install"
            >
                Installer l'appli
            </button>
        </div>
    </div>

    <div class="bg-gradient-to-r from-noz-blue to-blue-600 rounded-xl shadow-lg mb-8 p-8 text-white relative overflow-hidden">
        <!-- Decorative Circle -->
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-white opacity-10 transform rotate-45"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="text-center md:text-left animate-fade-in-up">
                <h1 class="text-3xl md:text-5xl font-extrabold mb-2 tracking-tight">
                    ARRIVAGES DU JOUR
                    <span class="inline-block ml-2 bg-yellow-400 text-noz-blue text-xs px-2 py-1 rounded-full align-middle animate-pulse">NOUVEAU</span>
                </h1>
                <p class="text-lg md:text-xl text-white max-w-2xl">
                    Découvrez nos pépites du moment. Ajoutez à votre panier, récupérez en magasin !
                </p>
            </div>
            
            <!-- Animated Icon -->
            <div class="hidden md:block animate-bounce-slow">
                <svg class="w-24 h-24 text-yellow-400 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"></path>
                </svg>
            </div>
        </div>
    </div>

    <div>
    <div class="mb-6">
        <form action="{{ path('app_home') }}" method="get" class="max-w-2xl mx-auto" data-controller="autosubmit" role="search" aria-label="Recherche de produits">
            {% if min_price %}<input type="hidden" name="min_price" value="{{ min_price }}">{% endif %}
            {% if max_price %}<input type="hidden" name="max_price" value="{{ max_price }}">{% endif %}
            {% if availability %}<input type="hidden" name="availability" value="{{ availability }}">{% endif %}
            {% if sort %}<input type="hidden" name="sort" value="{{ sort }}">{% endif %}
            {% if currentCategory %}<input type="hidden" name="category" value="{{ currentCategory }}">{% endif %}
            
            <label for="search-input" class="sr-only">Rechercher un produit</label>
            <div class="flex flex-col sm:flex-row gap-2">
                <input type="text" id="search-input" name="search" value="{{ search }}" placeholder="Rechercher un produit..." 
                       data-action="input->autosubmit#debouncedSubmit"
                       class="flex-grow shadow appearance-none border rounded py-3 px-4 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-3 px-6 rounded">
                    Rechercher
                </button>
                <button type="button" 
                        onclick="toggleFilters()"
                        id="filter-toggle-btn"
                        aria-expanded="{% if (min_price or max_price or availability or currentCategory) %}true{% else %}false{% endif %}"
                        aria-controls="filters-container"
                        class="bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold py-3 px-6 rounded flex items-center justify-center gap-2 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                    </svg>
                    <span id="filter-btn-text">{% if (min_price or max_price or availability or currentCategory) %}Masquer Filtres{% else %}Filtres{% endif %}</span>
                </button>
                {% if search %}
                    <a href="{{ path('app_home') }}" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-3 px-6 rounded">
                        Effacer
                    </a>
                {% endif %}
            </div>
        </form>
    </div>

    <!-- Filters and Sorting -->
    <div id="filters-container" class="{% if not (min_price or max_price or availability or currentCategory) %}hidden{% endif %} mb-6 bg-white rounded-lg shadow-md p-4 animate-fade-in">
        <form action="{{ path('app_home') }}" method="get" class="space-y-4" data-controller="autosubmit" aria-label="Filtres de produits">
            <!-- Keep search value -->
            {% if search %}
                <input type="hidden" name="search" value="{{ search }}">
            {% endif %}

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                <!-- Price Range -->
                <div>
                    <label for="min-price-input" class="block text-sm font-bold text-gray-700 mb-2">Prix minimum</label>
                    <input type="number" id="min-price-input" name="min_price" value="{{ min_price }}" step="0.01" min="0" 
                           placeholder="0.00 €"
                           data-action="input->autosubmit#debouncedSubmit"
                           class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                </div>
 
                <div>
                    <label for="max-price-input" class="block text-sm font-bold text-gray-700 mb-2">Prix maximum</label>
                    <input type="number" id="max-price-input" name="max_price" value="{{ max_price }}" step="0.01" min="0" 
                           placeholder="999.99 €"
                           data-action="input->autosubmit#debouncedSubmit"
                           class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                </div>
 
                <!-- Availability -->
                <div>
                    <label for="availability-select" class="block text-sm font-bold text-gray-700 mb-2">Disponibilité</label>
                    <select id="availability-select" name="availability" 
                            data-action="change->autosubmit#submit"
                            class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                        <option value="">Tous</option>
                        <option value="in_stock" {% if availability == 'in_stock' %}selected{% endif %}>En stock</option>
                        <option value="out_of_stock" {% if availability == 'out_of_stock' %}selected{% endif %}>Rupture</option>
                        <option value="promotion" {% if availability == 'promotion' %}selected{% endif %}>En promotion</option>
                    </select>
                </div>
 
                <!-- Sorting -->
                <div>
                    <label for="sort-select" class="block text-sm font-bold text-gray-700 mb-2">Trier par</label>
                    <select id="sort-select" name="sort" 
                            data-action="change->autosubmit#submit"
                            class="w-full shadow appearance-none border rounded py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline">
                        <option value="newest" {% if sort == 'newest' %}selected{% endif %}>Plus récents</option>
                        <option value="oldest" {% if sort == 'oldest' %}selected{% endif %}>Plus anciens</option>
                        <option value="price_asc" {% if sort == 'price_asc' %}selected{% endif %}>Prix croissant</option>
                        <option value="price_desc" {% if sort == 'price_desc' %}selected{% endif %}>Prix décroissant</option>
                        <option value="name_asc" {% if sort == 'name_asc' %}selected{% endif %}>Nom A-Z</option>
                    </select>
                </div>
 
                <!-- Category -->
                <div>
                    <label for="category-select" class="block text-sm font-bold text-gray-700 mb-2">Catégorie</label>
                    <select id="category-select" name="category" 
                            data-action="change->autosubmit#submit"
                            class="w-full shadow appearance-none border rounded py-2 px-3 text-noz-blue font-bold leading-tight focus:outline-none focus:shadow-outline bg-blue-50">
                        <option value="">Toutes catégories</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {% if currentCategory == category.id %}selected{% endif %}>
                                {{ category.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="flex gap-2 justify-end">
                <noscript>
                    <button type="submit" class="bg-noz-btn hover:bg-blue-700 text-white font-bold py-2 px-6 rounded">
                        Appliquer les filtres
                    </button>
                </noscript>
                <a href="{{ path('app_home') }}" class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-2 px-6 rounded">
                    Réinitialiser
                </a>
            </div>
        </form>
    </div>
    </div>
    
    <!-- Résumé live / compte à rebours -->
    <div class="mb-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div class="text-gray-600">
            <strong data-live-display-target="count">{{ products|length }}</strong> produit(s) actuellement en ligne
        </div>

        <div data-live-display-target="badge" class="{{ not liveInProgress ? 'hidden' : '' }}">
            <div class="flex items-center gap-2">
                <span class="flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-3 w-3 rounded-full bg-red-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
                </span>
                <span class="text-sm font-bold text-red-600 uppercase tracking-wider">Live en cours</span>
            </div>
        </div>

        <div data-live-display-target="countdownContainer" class="{{ liveInProgress ? 'hidden' : '' }}">
            {% if nextLiveAt %}
                <div id="next-live-countdown" data-next-live="{{ nextLiveAt|date('c') }}" class="flex items-center gap-3 text-base md:text-lg bg-blue-50 border border-noz-blue text-noz-blue px-4 py-3 rounded-xl shadow-sm" aria-live="polite">
                    <span class="font-semibold">Prochain live&nbsp;: </span>
                    <span class="font-mono next-live-countdown-value text-xl md:text-2xl">calcul en cours...</span>
                </div>
            {% else %}
                <div class="text-sm md:text-base text-gray-500 italic">Pas de live prévu pour le moment.</div>
            {% endif %}
        </div>
    </div>
    
    <div data-controller="live-display"
         data-live-display-mercure-url-value="{{ mercure('https://nozamberieu.fr/live/products') }}"
         data-live-display-initial-url-value="{{ path('api_live_products') }}">
        
        <div data-live-display-target="container" 
             class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
            {% for product in products %}
                <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 transition-all hover:shadow-xl group">
                    <div class="relative h-48 sm:h-64 overflow-hidden">
                        {% if product.imageFilename %}
                            <img src="{{ asset('uploads/images/' ~ product.imageFilename) }}" 
                                 alt="{{ product.name }}" 
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center bg-gray-50">
                                <svg class="w-16 h-16 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        {% endif %}
                        
                        <div class="absolute top-3 left-3 bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full animate-pulse flex items-center gap-1">
                            <span class="w-2 h-2 bg-white rounded-full"></span> EN LIVE
                        </div>

                        {% if product.stock <= 0 %}
                            <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center text-white font-bold text-xl uppercase tracking-widest">Épuisé</div>
                        {% endif %}
                    </div>
                    
                    <div class="p-5">
                        <h3 class="text-lg font-bold text-gray-900 mb-1 group-hover:text-noz-blue transition-colors">{{ product.name }}</h3>
                        
                        <div class="flex items-baseline mb-4">
                            <span class="text-2xl font-black text-noz-blue">{{ product.price|number_format(2, ',', ' ') }} €</span>
                            {% if product.originalPrice and product.originalPrice > product.price %}
                                <span class="text-sm line-through text-gray-400 ml-2">{{ product.originalPrice|number_format(2, ',', ' ') }} €</span>
                            {% endif %}
                        </div>

                        <div class="flex items-center justify-between">
                            <div class="text-sm">
                                <span class="{{ product.stock <= 5 ? 'text-red-600 font-bold' : 'text-gray-500' }}">
                                    {% if product.stock > 0 %}
                                        Stock : {{ product.stock }}
                                    {% else %}
                                        Rupture de stock
                                    {% endif %}
                                </span>
                            </div>
                            
                            {% if product.stock > 0 %}
                                <a href="{{ path('app_product_show_public', {'id': product.id}) }}" class="bg-noz-yellow text-noz-black font-bold px-4 py-2 rounded-lg hover:bg-yellow-400 transition-all flex items-center gap-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                    </svg>
                                    Détail
                                </a>
                            {% else %}
                                <button disabled class="bg-gray-200 text-gray-400 font-bold px-4 py-2 rounded-lg cursor-not-allowed grayscale">
                                    Épuisé
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div data-live-display-target="noProductMessage" class="{{ products|length > 0 ? 'hidden' : '' }} text-center py-20 bg-white rounded-3xl shadow-sm border border-dashed border-gray-200 pb-4">
            <div class="mb-4 flex justify-center">
                <div class="flex items-center gap-2">
                    <svg class="w-20 h-20 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    <span class="flex h-4 w-4 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500"></span>
                    </span>
                </div>
            </div>
            <div class="mt-2 flex flex-col items-center gap-1">
                {% if nextLiveAt %}
                    <div class="text-sm uppercase tracking-wider text-gray-500">Prochain live</div>
                    <div class="font-mono next-live-countdown-value text-3xl md:text-4xl font-extrabold text-noz-blue">calcul en cours...</div>
                {% else %}
                    <div class="text-lg font-semibold text-gray-700">Pas de live prévu pour le moment.</div>
                    <p class="text-gray-500 max-w-md mx-auto">Restez connectés, les prochains lives seront annoncés ici.</p>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Pagination -->
    {% if totalPages > 1 %}
        <div class="mt-8 flex justify-center">
            <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination des produits">
                <!-- Previous -->
                {% if currentPage > 1 %}
                    <a href="{{ path('app_home', {page: currentPage - 1, search: search, min_price: min_price, max_price: max_price, availability: availability, sort: sort, category: currentCategory}) }}" 
                       class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                        ‹ Précédent
                    </a>
                {% else %}
                    <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-gray-50 text-sm font-medium text-gray-500 cursor-not-allowed" aria-disabled="true">
                        ‹ Précédent
                    </span>
                {% endif %}

                <!-- Page numbers -->
                {% for page in 1..totalPages %}
                    {% if page == currentPage %}
                        <span aria-current="page" class="relative inline-flex items-center px-4 py-2 border border-noz-blue bg-noz-blue text-sm font-medium text-white">
                            {{ page }}
                        </span>
                    {% elseif page == 1 or page == totalPages or (page >= currentPage - 2 and page <= currentPage + 2) %}
                        <a href="{{ path('app_home', {page: page, search: search, min_price: min_price, max_price: max_price, availability: availability, sort: sort, category: currentCategory}) }}" 
                           class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                            {{ page }}
                        </a>
                    {% elseif page == currentPage - 3 or page == currentPage + 3 %}
                        <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
                            ...
                        </span>
                    {% endif %}
                {% endfor %}

                <!-- Next -->
                {% if currentPage < totalPages %}
                    <a href="{{ path('app_home', {page: currentPage + 1, search: search, min_price: min_price, max_price: max_price, availability: availability, sort: sort, category: currentCategory}) }}" 
                       class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                        Suivant ›
                    </a>
                {% else %}
                    <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-gray-50 text-sm font-medium text-gray-500 cursor-not-allowed" aria-disabled="true">
                        Suivant ›
                    </span>
                {% endif %}
            </nav>
        </div>
    {% endif %}
</div>

<script>
// Compte à rebours jusqu'à la date programmée du prochain live
(function() {
    const valueEls = document.querySelectorAll('.next-live-countdown-value');
    if (!valueEls.length) {
        return;
    }

    const root = document.getElementById('next-live-countdown');
    const isoDate = root ? root.dataset.nextLive : null;
    if (!isoDate) {
        return;
    }

    const target = new Date(isoDate);
    if (isNaN(target.getTime())) {
        return;
    }

    function update() {
        const now = new Date();
        let diff = Math.max(0, target.getTime() - now.getTime());

        const totalSeconds = Math.floor(diff / 1000);
        const days = Math.floor(totalSeconds / 86400);
        const hours = Math.floor((totalSeconds % 86400) / 3600);
        const minutes = Math.floor((totalSeconds % 3600) / 60);
        const seconds = totalSeconds % 60;

        const text = `${days}j ${hours.toString().padStart(2, '0')}h ${minutes.toString().padStart(2, '0')}m ${seconds.toString().padStart(2, '0')}s`;

        valueEls.forEach(function(el) {
            el.textContent = text;
        });
    }

    update();
    setInterval(update, 1000);
})();
</script>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "NOZ Amberieu-en-Bugey",
  "image": "{{ absolute_url(asset('uploads/images/noz-logo-og.png')) }}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "19 rue Vermorel",
    "addressLocality": "Ambérieu-en-Bugey",
    "postalCode": "01500",
    "addressCountry": "FR"
  },
  "url": "{{ absolute_url(path('app_home')) }}",
  "telephone": "+33486800039",
  "priceRange": "€",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday"
      ],
      "opens": "09:30",
      "closes": "19:30"
    }
  ]
}
</script>
<script>
    function toggleFilters() {
        const container = document.getElementById('filters-container');
        const textBtn = document.getElementById('filter-btn-text');
        
        if (container.classList.contains('hidden')) {
            container.classList.remove('hidden');
            textBtn.textContent = 'Masquer Filtres';
        } else {
            container.classList.add('hidden');
            textBtn.textContent = 'Filtres';
        }
    }
</script>
{% endblock %}
